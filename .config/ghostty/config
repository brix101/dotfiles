# Config generated by Ghostty Config
theme = catppuccin-mocha

term = xterm-256color
clipboard-read = allow
copy-on-select = true

# Opacity of split windows
unfocused-split-opacity = 0.97  

# Set the background-opacity to be fully opaque
background-opacity = 1.0

font-thicken = true
font-family = JetBrains Mono Light
font-family-bold = JetBrains Mono Bold
font-family-italic = JetBrains Mono Italic
font-family-bold-italic = JetBrains Mono Bold Italic
